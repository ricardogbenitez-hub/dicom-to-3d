# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# Virtual environments (all common names)
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/dist/
dist-ssr/

# ── Environment & secrets ────────────────────────────────────────────────────
# Ignore all .env variants at any depth; whitelist only the committed template
.env
.env.*
!.env.example

# ── Medical imaging data ─────────────────────────────────────────────────────
# NEVER commit patient data or raw medical imaging files
data/
*.dcm
*.DCM
*.nii
*.nii.gz

# ── Generated output (large binaries, fully reproducible from source) ────────
output/stl/
*.stl
*.3mf

# Renders: ignore everything inside; selectively keep PNGs/GIFs for the README
# Uses wildcard (not trailing slash) so negations can override per-file.
output/renders/*
!output/renders/*.png
!output/renders/*.gif

# ── API runtime artifacts ────────────────────────────────────────────────────
# Job IDs written to disk during manual testing
test_job_id.txt

# ── Development internals ────────────────────────────────────────────────────
# Internal task-prompt files used during development — not part of the public project
prompts/

# Claude Code local state (settings, caches, conversation history)
.claude/

# Project development notes — kept locally but not published
CLAUDE.md

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
desktop.ini
Thumbs.db
